@charset "utf-8";

* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { background: linear-gradient(135deg, rgb(20, 30, 48), rgb(36, 59, 85)); min-height: 100vh; font-family: Arial, sans-serif; color: white; }

.container { text-align: center; padding: 30px 20px; }

h1 { font-size: 40px; margin-bottom: 30px; }

.category-box { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; flex-wrap: wrap; }

button { background: rgb(0, 198, 255); color: white; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; padding: 14px 20px; border-radius: 12px; font-size: 16px; cursor: pointer; transition: 0.3s; }

button:hover { transform: scale(1.05); opacity: 0.9; }

.card { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(10px); border-radius: 20px; padding: 25px; margin-top: 30px; width: 95%; max-width: 600px; margin-left: auto; margin-right: auto; box-shadow: rgba(0, 198, 255, 0.2) 0px 0px 20px; }

h2 { font-size: 34px; margin-bottom: 20px; }

p { font-size: 20px; margin-bottom: 15px; }

textarea { width: 100%; height: 150px; border-width: medium; border-style: none; border-color: currentcolor; border-image: initial; border-radius: 12px; padding: 15px; font-size: 16px; resize: none; margin-top: 15px; outline: none; }

h3 { margin-top: 20px; color: rgb(0, 255, 204); }

@media (max-width: 600px) {
  h1 { font-size: 32px; }
  h2 { font-size: 28px; }
  button { width: 100%; }
}

.stats { display: flex; justify-content: center; gap: 15px; margin: 25px 0px; flex-wrap: wrap; }

.stat-card { background: rgba(255, 255, 255, 0.1); padding: 15px; border-radius: 15px; min-width: 110px; backdrop-filter: blur(10px); box-shadow: rgba(0, 198, 255, 0.2) 0px 0px 15px; }

.stat-card h4 { margin-bottom: 10px; color: rgb(0, 198, 255); }

.stat-card p { font-size: 20px; font-weight: bold; }
